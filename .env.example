# --- server ---
PORT=3000                      # injected by Portless in real dev
DB_PATH=./data/app.db

# --- auth ---
JWT_SECRET=change-me-locally
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# --- web ---
CORS_ORIGIN=https://app.social.localhost
COOKIE_SECURE=true
CSRF_ENABLED=true

# --- simulator ---
SIM_ENABLED=true
SIM_INTERVAL_MS=4000
SIM_ACTIONS_PER_TICK=1
SIM_CONTROL_ENABLED=true       # expose /sim/* endpoints
