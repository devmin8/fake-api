meta {
  name: Me Unauthed
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/auth/me
  body: none
  auth: none
}

assert {
  res.status: eq 401
  res.body.error.code: eq UNAUTHENTICATED
}

docs {
  Runs first in this folder — *before* login — so no session exists yet and the
  collection pre-request injects no auth cookie. That proves the 401 boundary
  without fighting the pre-request injection order. (logout in 99-teardown nulls
  the captured vars, so a re-run starts clean here too.)
}
