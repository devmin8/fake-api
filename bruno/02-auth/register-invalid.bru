meta {
  name: Register Invalid
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "username": "x",
    "email": "not-an-email",
    "password": "short",
    "displayName": ""
  }
}

assert {
  res.status: eq 422
  res.body.error.code: eq VALIDATION_ERROR
}
