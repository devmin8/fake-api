meta {
  name: Like Unauthed
  type: http
  seq: 150
}

post {
  url: {{baseUrl}}/api/posts/{{likePostId}}/like
  body: none
  auth: none
}

script:pre-request {
  // Clobber the injected session cookie so the request arrives unauthenticated;
  // the auth guard 401s before touching the like service.
  req.setHeader('Cookie', 'x=1');
}

assert {
  res.status: eq 401
  res.body.error.code: eq UNAUTHENTICATED
}
