meta {
  name: Mark Read Not Found
  type: http
  seq: 72
}

post {
  url: {{baseUrl}}/api/notifications/no-such-id/read
  body: none
  auth: none
}

assert {
  res.status: eq 404
  res.body.error.code: eq NOT_FOUND
}

docs {
  A notification id that doesn't exist (or isn't yours) → 404, never a reveal.
}
